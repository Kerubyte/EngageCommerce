<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/userDataHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/image_profile_action"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/rick"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:riv_oval="true" />

        <View
            android:id="@+id/viewSupport"
            android:layout_width="1dp"
            android:layout_height="1dp"
            app:layout_constraintBottom_toBottomOf="@+id/image_profile_action"
            app:layout_constraintEnd_toEndOf="@+id/image_profile_action"
            app:layout_constraintStart_toStartOf="@+id/image_profile_action"
            app:layout_constraintTop_toTopOf="@+id/image_profile_action" />

        <TextView
            android:id="@+id/text_first_name_value_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/header_first_name_placeholder"
            android:textColor="@color/primaryTextColor"
            android:textSize="18sp"
            app:layout_constraintBottom_toTopOf="@id/viewSupport"
            app:layout_constraintStart_toEndOf="@+id/image_profile_action" />

        <TextView
            android:id="@+id/text_last_name_value_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:fontFamily="@font/muli"
            android:text="@string/last_name_placeholder"
            android:textColor="@color/primaryTextColor"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/text_first_name_value_header"
            app:layout_constraintStart_toEndOf="@+id/text_first_name_value_header"
            app:layout_constraintTop_toTopOf="@+id/text_first_name_value_header" />

        <TextView
            android:id="@+id/text_email_value_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/muli"
            android:text="@string/email_placeholder"
            android:textColor="@color/primaryTextColor"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@+id/image_profile_action"
            app:layout_constraintTop_toBottomOf="@+id/viewSupport" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>